# Copy this file to .env and replace values as needed.
SECRET_KEY=replace-with-a-strong-random-value
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,.vercel.app
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://*.vercel.app
ADMIN_PATH=secure-admin-panel-2026

# Local development (SQLite)
DATABASE_URL=sqlite:///db.sqlite3

# Production (recommended - PostgreSQL)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
